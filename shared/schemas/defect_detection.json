{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DefectDetectionResult",
  "type": "object",
  "properties": {
    "model_version": {
      "type": "string",
      "description": "Version of the YOLO model used for inference"
    },
    "filename": {
      "type": "string",
      "description": "Name of the analyzed image file"
    },
    "image_path": {
      "type": "string",
      "description": "Absolute or relative path to the image"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Inference completion timestamp in ISO 8601 format"
    },
    "image_size": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      },
      "required": ["width", "height"]
    },
    "inference_time_ms": {
      "type": "number",
      "description": "Time taken for inference in milliseconds"
    },
    "has_defect": {
      "type": "boolean",
      "description": "True if at least one defect was detected"
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class": {
            "type": "string",
            "enum": ["crazing", "inclusion", "patches", "pitted_surface", "rolled-in_scale", "scratches"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "severity": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"]
          },
          "bbox": {
            "type": "object",
            "properties": {
              "xmin": { "type": "number" },
              "ymin": { "type": "number" },
              "xmax": { "type": "number" },
              "ymax": { "type": "number" }
            },
            "required": ["xmin", "ymin", "xmax", "ymax"]
          }
        },
        "required": ["class", "confidence", "severity", "bbox"]
      }
    }
  },
  "required": [
    "model_version",
    "filename",
    "image_path",
    "timestamp",
    "image_size",
    "inference_time_ms",
    "has_defect",
    "defects"
  ]
}
