{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DefectDetectionResult",
  "type": "object",
  "properties": {
    "model_version": {
      "type": "string",
      "description": "추론에 사용된 YOLO 모델의 버전"
    },
    "filename": {
      "type": "string",
      "description": "분석 대상 이미지 파일명"
    },
    "image_path": {
      "type": "string",
      "description": "이미지 파일의 절대 혹은 상대 물리 경로"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "추론이 완료된 시점의 ISO 8601 형식 타임스탬프"
    },
    "image_size": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      },
      "required": ["width", "height"]
    },
    "inference_time_ms": {
      "type": "number",
      "description": "밀리초(ms) 단위의 추론 소요 시간"
    },
    "has_defect": {
      "type": "boolean",
      "description": "결함이 1개 이상 검출되었는지 여부 (참/거짓)"
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class": {
            "type": "string",
            "enum": ["crazing", "inclusion", "patches", "pitted_surface", "rolled-in_scale", "scratches"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "severity": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"]
          },
          "bbox": {
            "type": "object",
            "properties": {
              "xmin": { "type": "number" },
              "ymin": { "type": "number" },
              "xmax": { "type": "number" },
              "ymax": { "type": "number" }
            },
            "required": ["xmin", "ymin", "xmax", "ymax"]
          }
        },
        "required": ["class", "confidence", "severity", "bbox"]
      }
    }
  },
  "required": [
    "model_version",
    "filename",
    "image_path",
    "timestamp",
    "image_size",
    "inference_time_ms",
    "has_defect",
    "defects"
  ]
}
